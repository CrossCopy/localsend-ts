{
	"name": "localsend",
	"module": "src/index.ts",
	"types": "src/index.ts",
	"version": "0.1.2",
	"type": "module",
	"repository": "https://github.com/CrossCopy/localsend-ts.git",
	"bin": {
		"localsend": "./dist/cli.js",
		"localsend-interactive": "./dist/cli-interactive.js"
	},
	"scripts": {
		"build": "bun build.ts",
		"postbuild": "verify-package-export verify",
		"openapi:dump": "bun tools/generate-openapi.ts",
		"check-types": "tsc --noEmit",
		"dev": "bun run --watch dev.ts",
		"format": "prettier --write .",
		"test": "bun test",
		"test:e2e:docker": "LOCALSEND_E2E_DOCKER=1 bun test test/e2e-docker",
		"oracle:build": "cd tools/oracle-rs && cargo build --release",
		"test:oracle": "LOCALSEND_ORACLE=1 bun test test/oracle",
		"cli": "bun src/cli-interactive.ts",
		"cli:dev": "bun --watch src/cli-interactive.ts",
		"tui": "bun src/cli-tui.tsx",
		"tui:dev": "bun --watch src/cli-tui.tsx"
	},
	"exports": {
		".": "./src/index.ts",
		"./types": "./src/types.ts",
		"./sdk": "./src/sdk/index.ts",
		"./sdk/client": "./src/sdk/client.gen.ts",
		"./hono-rpc": "./src/hono-rpc.ts"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@hey-api/openapi-ts": "^0.99.0",
		"@types/bun": "latest",
		"@types/node-forge": "^1.3.14",
		"@types/react": "^19.2.17",
		"citty": "^0.2.2",
		"prettier": "^3.5.3",
		"typescript": "^5.9.0",
		"verify-package-export": "^0.0.3"
	},
	"peerDependencies": {
		"typescript": ">=5.0.0"
	},
	"dependencies": {
		"@hey-api/client-fetch": "^0.13.1",
		"@hono/node-server": "^2.0.8",
		"@hono/standard-validator": "^0.2.3",
		"@scalar/hono-api-reference": "^0.11.9",
		"@standard-community/standard-openapi": "0.2.9",
		"@types/cli-progress": "^3.11.6",
		"@types/json-schema": "^7.0.15",
		"@valibot/to-json-schema": "^1.7.1",
		"cli-progress": "^3.12.0",
		"hono": "^4.12.29",
		"hono-openapi": "^1.3.1",
		"ink": "^6.6.0",
		"node-forge": "^1.4.0",
		"openapi-types": "^12.1.3",
		"pretty-bytes": "^7.1.0",
		"react": "^19.2.7",
		"undici": "^8.7.0",
		"valibot": "^1.4.2"
	},
	"files": [
		"dist",
		"src",
		"openapi.json"
	]
}
