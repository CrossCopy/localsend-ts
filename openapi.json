					"200": {
						"description": "Device information",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"alias": {
											"type": "string"
										},
										"version": {
											"type": "string"
										},
										"deviceModel": {
											"anyOf": [
												{
													"type": "string"
												},
												{
													"type": "null"
												}
											]
										},
										"deviceType": {
											"anyOf": [
												{
													"type": "string"
												},
												{
													"type": "null"
												}
											]
										},
										"fingerprint": {
											"type": "string"
										},
										"port": {
											"type": "number"
										},
										"protocol": {
											"anyOf": [
												{
													"const": "http"
												},
												{
													"const": "https"
												}
											],
											"default": "http"
										},
										"download": {
											"type": "boolean",
											"default": false
										}
									},
									"required": [
										"alias",
										"version",
										"fingerprint",
										"port"
									]
								}
							}
						}
					}
				}
			}
